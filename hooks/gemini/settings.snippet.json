{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/hooks/session-state.mjs\"",
            "commandWindows": "node \"$((git rev-parse --show-toplevel).Trim())\\hooks\\session-state.mjs\""
          }
        ]
      }
    ],
    "BeforeTool": [
      {
        "matcher": "read_file|write_file|replace|run_shell_command",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/hooks/privacy-block.mjs\"",
            "commandWindows": "node \"$((git rev-parse --show-toplevel).Trim())\\hooks\\privacy-block.mjs\""
          }
        ]
      },
      {
        "matcher": "run_shell_command",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/hooks/ship-gate.mjs\"",
            "commandWindows": "node \"$((git rev-parse --show-toplevel).Trim())\\hooks\\ship-gate.mjs\""
          }
        ]
      }
    ],
    "AfterTool": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/hooks/monitoring.mjs\"",
            "commandWindows": "node \"$((git rev-parse --show-toplevel).Trim())\\hooks\\monitoring.mjs\""
          }
        ]
      }
    ]
  }
}
