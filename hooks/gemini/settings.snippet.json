{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "node \"$(git rev-parse --show-toplevel)/hooks/session-state.mjs\"" }
        ]
      }
    ],
    "BeforeTool": [
      {
        "matcher": "read_file|write_file|replace|run_shell_command",
        "hooks": [
          { "type": "command", "command": "node \"$(git rev-parse --show-toplevel)/hooks/privacy-block.mjs\"" }
        ]
      },
      {
        "matcher": "run_shell_command",
        "hooks": [
          { "type": "command", "command": "node \"$(git rev-parse --show-toplevel)/hooks/ship-gate.mjs\"" }
        ]
      }
    ],
    "AfterTool": [
      {
        "matcher": ".*",
        "hooks": [
          { "type": "command", "command": "node \"$(git rev-parse --show-toplevel)/hooks/monitoring.mjs\"" }
        ]
      }
    ]
  }
}
